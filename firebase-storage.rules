rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{expenseId} {
      // Cualquier usuario autenticado puede leer receipts (la pareja via Firestore RLS)
      allow read: if request.auth != null;
      // Solo usuarios autenticados pueden escribir (validación adicional en cliente)
      allow write: if request.auth != null;
    }
  }
}
